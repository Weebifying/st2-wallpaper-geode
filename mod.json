{
	"geode": "5.6.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"version": "v22.0.81",
	"id": "weebify.st2_wallpaper",
	"name": "ST2 Wallpaper",
	"developers": [
		"Weebify",
		"Spectra"
	],
	"description": "Custom Menu Wallpaper for Sunix Thingy 2",
	"resources": {
		"files": [
			"res/*.png",
			"res/*.plist"
		]
	},
	"dependencies": {
		"geode.node-ids": ">=1.23.1"
	},
	"settings": {
		"only_main": {
			"name": "Wallpaper in only Main Menu",
			"type": "bool",
			"default": false
		},
		"particles": {
			"name": "Toggle particles",
			"type": "bool",
			"default": true
		}
	}
}